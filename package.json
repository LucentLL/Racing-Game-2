{
  "name": "driver-city",
  "version": "9.0.0-alpha.0",
  "description": "Driver City — GBC-aesthetic top-down racing game set in 1999 Charlotte, NC",
  "type": "module",
  "private": true,
  "author": "LucentLL",
  "scripts": {
    "dev": "vite",
    "sprites:buffer": "node scripts/measureSprite.mjs --emit > src/config/cars/spriteBuffer.ts",
    "sprites:check": "node scripts/measureSprite.mjs --check",
    "build": "npm run sprites:check && tsc --noEmit && vite build",
    "build:app": "npm run sprites:check && vite build --mode development",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "cap": "cap",
    "cap:build": "vite build && cap sync",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:run:android": "cap run android"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/cli": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor-community/in-app-review": "^7.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
