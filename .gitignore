# Capacitor — `npx cap add android` generates this; let
# developers re-add per machine rather than tracking the
# entire Android project. Keep capacitor.config.ts checked in
# (it's the source of truth).
android/
ios/

# Claude Code local settings
.claude/settings.local.json

# Backup files
*.bak
*.orig

# Spreadsheet inspection artifacts. `GT4 Specs.xlsx` itself stays
# committed; the unpacked / parsed scratch outputs are throwaway.
gt4_unpacked/

# Standalone-build outputs (build-standalone.ps1) - 85MB+ each;
# rebuild locally, never track.
DriverCity.exe
app/
build-out.log
